      //modulationOperator[5]+=modulationFreq[5];
      "lds r0,  wDDS + 5*WAVE_DDS_SIZE + OFFSET_M_FREQ\n"
      "lds r1,  wDDS + 5*WAVE_DDS_SIZE + OFFSET_M_FREQ + 1\n"
      "lds r16, wDDS + 5*WAVE_DDS_SIZE + OFFSET_M_OP\n"
      "lds r17, wDDS + 5*WAVE_DDS_SIZE + OFFSET_M_OP + 1\n"
      "add r16, r0\n"
      "adc r17, r1\n"
      "sts wDDS + 5*WAVE_DDS_SIZE + OFFSET_M_OP,r16\n"
      "sts wDDS + 5*WAVE_DDS_SIZE + OFFSET_M_OP + 1,r17\n"
      //fetch aligned modularSamplingTable[5] start hi8 address.
      "lds r31, wDDS + 5*WAVE_DDS_SIZE + OFFSET_M_ST + 1\n"
      //move modulationOperator[5]>>8
      "mov r30, r17\n"
      //modulationFeedback.
      //Z reg indirectly reference.
      "lpm r18, Z\n"
      "lds r19, wDDS + 5*WAVE_DDS_SIZE + OFFSET_FEEDBACK_GAIN\n"
      //apply feedback gain. 
      "mulsu r18, r19\n"
      //modulationOperator[5]+feedbackAmp
      "add r30, r1\n"
      //fetch Modulation Envelope.
      //"lds r19, %[mOutputDutyCH5]\n"
      "lds r19, env + 12*ENV_SIZE + OFFSET_OUTPUTDUTY\n"
      //fetch modulation Duty from SamplingTable[5].
      "lpm r18, Z\n"
      //apply Modulation Envelope.
      "mulsu r18, r19\n"
      //carrierOperator[5]+=CON[5].freq;
      "lds r30, CON + 5*CON_SIZE + OFFSET_CONDUCTOR_FREQ\n"
      "lds r31, CON + 5*CON_SIZE + OFFSET_CONDUCTOR_FREQ + 1\n"
      "lds r16, wDDS + 5*WAVE_DDS_SIZE + OFFSET_C_OP\n"
      "lds r17, wDDS + 5*WAVE_DDS_SIZE + OFFSET_C_OP + 1\n"
      "add r16, r30\n"
      "adc r17, r31\n"
      "sts wDDS + 5*WAVE_DDS_SIZE + OFFSET_C_OP,r16\n"
      "sts wDDS + 5*WAVE_DDS_SIZE + OFFSET_C_OP + 1,r17\n"
      //carrierDetuneOperator[5]+=carrierDetuneFreq[5];
      "lds r30, wDDS + 5*WAVE_DDS_SIZE + OFFSET_CD_FREQ\n"
      "lds r31, wDDS + 5*WAVE_DDS_SIZE + OFFSET_CD_FREQ + 1\n"
      "lds r18, wDDS + 5*WAVE_DDS_SIZE + OFFSET_CD_OP\n"
      "lds r19, wDDS + 5*WAVE_DDS_SIZE + OFFSET_CD_OP + 1\n"
      "add r18, r30\n"
      "adc r19, r31\n"
      "sts wDDS + 5*WAVE_DDS_SIZE + OFFSET_CD_OP,r18\n"
      "sts wDDS + 5*WAVE_DDS_SIZE + OFFSET_CD_OP + 1,r19\n"
      //add modulation Duty to carrierOperator[5] and carrierDetuneOperator[5].
      "add r16, r0\n"
      "adc r17, r1\n"
      "add r18, r0\n"
      "adc r19, r1\n"
      //fetch aligned carrierSamplingTable[5] start hi8 address.
      "lds r31, wDDS + 5*WAVE_DDS_SIZE + OFFSET_C_ST + 1\n"
      //fetch carrier Duty from SamplingTable[5].
      "mov r30, r17\n"
      "lpm r16, Z\n"
      //fetch aligned carrierDetuneSamplingTable[5] start hi8 address.
      "lds r31, wDDS + 5*WAVE_DDS_SIZE + OFFSET_CD_ST + 1\n"
      "mov r30, r19\n"
      "lpm r18, Z\n"
      //apply carrier and carrierDetune Envelope.synthesis output.
      //"lds r17, %[cOutputDutyCH5]\n"
      "lds r17, env + 5*ENV_SIZE + OFFSET_OUTPUTDUTY\n"
      "lds r19, wDDS + 5*WAVE_DDS_SIZE + OFFSET_OUTPUT_CD_DUTY\n"
      "mulsu r16, r17\n"
      "movw r30, r0\n"
      "mulsu r18, r19\n"
      "add r30, r0\n"
      "adc r31, r1\n"
      //"sbrc r31, 7\n"
      //"dec r22\n" //when negatine duty, cast int16 to int24.
      "add r20, r30\n"
      "adc r21, r31\n"
      "adc r22, r2\n"
      "lsl r31\n"
      "sbci r22, 0\n"

      //noise genarate. ノイズ結果をr22に保存
      //noiseOperator+=CON[6].freq;
      "lds r0,  CON + 6*CON_SIZE + OFFSET_CONDUCTOR_FREQ\n"
      "lds r1,  CON + 6*CON_SIZE + OFFSET_CONDUCTOR_FREQ + 1\n"
      "lds r18, %[noiseOperator]\n"
      "lds r19, %[noiseOperator] + 1\n"
      "add r18, r0\n"
      "adc r19, r1\n"
      "sts %[noiseOperator],r18\n"
      "sts %[noiseOperator] + 1,r19\n"
      //キャリー検出分岐
      "brcc notCarry\n"
    "isCarry:"
      "lds r16, %[noiseMode]\n"
      "cpi r16, 0x00\n"
      "breq noiseMode0\n"//一致で分岐
      "cpi r16, 0x01\n"
      "breq noiseMode1\n"//一致で分岐
      "cpi r16, 0x02\n"
      "breq noiseMode2\n"//一致で分岐
    "noiseMode0:"
      //noise=(getADC&0x01)^(getADC&0x02)>>1;
      //ADCSRA|=0b01000000;
      "lds r16, 0x79\n"//ADCH取得
      "lds r17, 0x7A\n"//ADCSRA取得
      "ori r17, 0x40\n"//ADC変換開始
      "sts 0x7A, r17\n"//
      "lds r17, %[noise]\n"
      "eor r17, r16\n"
      "sts %[noise], r17\n"
      "rjmp notCarry\n"
    "noiseMode1:"
      //noiseRegister>>=1;
      //noiseRegister |= ((noiseRegister^(noiseRegister>>1))&1)<<15;
      //noise=noiseRegister;
      "lds r16, %[noiseRegister]\n"
      "lds r17, %[noiseRegister] + 1\n"
      "lsr r17\n" //上位バイト右シフト
      "ror r16\n" //キャリーを含めた下位バイト右シフト
      "movw r18, r16\n"
      "ror r18\n" //キャリーを含めた下位バイト右シフト
      "rjmp LFSR\n"
    "noiseMode2:"
      //noiseRegister>>=1;
      //noiseRegister |= ((noiseRegister^(noiseRegister>>6))&1)<<15;
      //noise=noiseRegister;
      "lds r16, %[noiseRegister]\n"
      "lds r17, %[noiseRegister] + 1\n"
      "lsr r17\n" //上位バイト右シフト
      "ror r16\n" //キャリーを含めた下位バイト右シフト
      "movw r18, r16\n"
      "rol r16\n" //キャリーを含めた上位バイト左シフト
      "rol r16\n" //キャリーを含めた上位バイト左シフト
    "LFSR:"
      "eor r18, r16\n"
      "andi r18, 0x01\n"
      "sbrc r18, 0\n"
      "ori r17, 0x80\n"
      "sts %[noiseRegister], r16\n"
      "sts %[noiseRegister] + 1, r17\n"
      "sts %[noise], r16\n"
    "notCarry:"
      //"lds r30, %[cOutputDutyCH6]\n"
      "lds r30, env + 6*ENV_SIZE + OFFSET_OUTPUTDUTY\n"
      "lds r20, %[noise]\n"
      "sbrs r20, 0\n"
      "rjmp noiseFalse\n"
    "noiseTrue:"
      "add r21, r30\n"
      "adc r22, r2\n"
      "rjmp output\n"
    "noiseFalse:"
      "sub r21, r30\n"
      "sbc r22, r2\n"
    "output:"
      "ser r16\n"     //0xFF
      "sbrc r22, 7\n" //7bit0で次命令スキップ
      "rjmp negDuty\n"
    "posDuty:"
      "com r21\n"
      "out 0x28, r16\n" //OCR0B設定
      "out 0x27, r21\n" //OCR0A設定
      "rjmp end\n"
    "negDuty:"
      "dec r21\n"  //255足す
      "out 0x27, r16\n" //OCR0A設定
      "out 0x28, r21\n" //OCR0B設定
    "end:"
      :
      :[con_size] "i" (sizeof(conductor)),
       [offset_conductorFreq] "i" (offsetof(conductor, freq)),
       [waveDDS_size] "i" (sizeof(waveDDS)),
       [offset_modularFeedbackGainDivide256] "i" (offsetof(waveDDS, modularFeedbackGainDivide256)),
       [offset_carrierSamplingTable] "i" (offsetof(waveDDS, carrierSamplingTable)),
       [offset_carrierDetuneSamplingTable] "i" (offsetof(waveDDS, carrierDetuneSamplingTable)),
       [offset_modularSamplingTable] "i" (offsetof(waveDDS, modularSamplingTable)),
       [offset_outputCarrierDetuneDuty] "i" (offsetof(waveDDS, outputCarrierDetuneDuty)),
       [offset_carrierDetuneFreq] "i" (offsetof(waveDDS, carrierDetuneFreq)),
       [offset_modularFreq] "i" (offsetof(waveDDS, modularFreq)),
       [offset_carrierOperator] "i" (offsetof(waveDDS, carrierOperator)),
       [offset_carrierDetuneOperator] "i" (offsetof(waveDDS, carrierDetuneOperator)),
       [offset_modularOperator] "i" (offsetof(waveDDS, modularOperator)),
       [env_size] "i" (sizeof(envelope)),
       [offset_outputDuty] "i" (offsetof(envelope, outputDuty)),
       [noiseRegister] "i" (&nDDS.noiseRegister),
       [noiseOperator] "i" (&nDDS.noiseOperator),
       [noiseMode] "i" (&nDDS.mode),
       [noise] "i" (&nDDS.noise)
      :"r0","r1","r2","r16","r17","r18","r19","r20","r21","r22","r30","r31" //duty 3byte r22:r21:r20
  );
}
ISR(TIMER2_COMPA_vect){ //基準時間生成
  asm(
    "lds r0, %[refMs]\n"
    "inc r0\n"
    "sts %[refMs], r0\n"
    :
    : [refMs] "i" (&refMs)
    :"r0"
  );
}
