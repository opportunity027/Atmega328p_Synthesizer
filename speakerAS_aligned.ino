void setup() {  //レジスタ初期化
  DDRD = 0b11111100; //入出力レジスタ初期化
  DDRC = 0b00000000;
  DDRB = 0b00000111;
  //ノイズ生成に乱数が必要のためADC使用
  ADMUX = 0b11000000; //PC0ポート(Arduino A0ピン)使用、ADC結果右揃え、内部1.1V基準電圧
  ADCSRA = 0b10000111;  //ADC有効　前置分周128
  ADCSRB = 0b00000000;  //ADC 連続変換動作
  //Timer0 initialize
  TCCR0A = 0b00000011;  //8bit位相基準PWM反転出力
  TCCR0B = 0b00000001;  //分周なし
  OCR0A = 255;
  OCR0B = 255;
  //Timer1 initialize
  TCCR1A = 0; // 初期化
  TCCR1B = 0b00001001; //前置分周なし CTCモード
  OCR1A = 749;         //Timer1 COMPA 32768Hz CTCカウンタ749上限に設定24.576MHz 
  //Timer2 initialize.
  TCCR2A = 0b00000010; // CTCモードに設定
  TCCR2B = 0b00000101; // 前置分周比128
  OCR2A = 191;        // Timer2 COMPA 1kHz 1msec CTCカウンタ191上限に設定24.576MHz
}
int16_t main (){
  setup ();
  sei();
  // do other stuff here  
  while(true){
    loop();
  };
}
void loop() { //メインルーチン
  static bool isBottonPushed = false;
  if(TIMSK2==0b00000000){
    if((PINC&0b00000010)==0b00000010&&!isBottonPushed){
      isBottonPushed = true;
      //wave channel init.
      struct envelope *cEnv_ptr = &cEnv(0);
      struct LFO *LFO_ptr = &LFO[0];
      struct conductor *CON_ptr = &CON[0];
      for(uint8_t c=0;c<=6;c++,cEnv_ptr++,LFO_ptr++,CON_ptr++){
        CON_ptr->returnAddress=0;
        CON_ptr->beepMs=0;
        CON_ptr->address=0;
        cEnv_ptr->nextWaitTimeMs=0;
        cEnv_ptr->attackCount=0;
        cEnv_ptr->decayCount=0;
        cEnv_ptr->sustainReleaseCount=0;
        LFO_ptr->mode=false;
        //初期パラメータセット
        CON_ptr->freq = pgm_read_word(beepFreqChAddressOffset[c])<<1;
        CON_ptr->beepDuration = pgm_read_word(beepDurationChAddressOffset[c]);
        if(c<=5){
          beepParmInit(c);
          uint32_t tmp;
          u16u16Mul(tmp, CON_ptr->freq, wDDS[c].detunePitchDivide32768);
          wDDS[c].carrierDetuneFreq=tmp>>15;
          u16u16Mul(tmp, CON_ptr->freq, wDDS[c].modularFreqRatioDivide256);
          wDDS[c].modularFreq=tmp>>8;
        }else{
          noiseParmInit();
        }
        if(CON_ptr->freq!=0){
          if(cEnv_ptr->attackDuration!=0){
            cEnv_ptr->status=ATTACK;
          }else if(cEnv_ptr->decayDuration!=0){
            cEnv_ptr->status=DECAY;
          }else if(cEnv_ptr->sustainDuration!=0){
            cEnv_ptr->status=SUSTAIN;
          }else if(cEnv_ptr->releaseDuration!=0){
            cEnv_ptr->status=RELEASE;
          }else{
            cEnv_ptr->status=CONSTANT;
          }
          if(cEnv_ptr->status==ATTACK){
            if(cEnv_ptr->isAllowOverrideAttackDuty){
              cEnv_ptr->calculatedDuty=0;
            }
          }else{
            cEnv_ptr->calculatedDuty=255;
          }
        }else{
          cEnv_ptr->status = MUTE;
        }
      }
      struct envelope *mEnv_ptr = &mEnv(0);
      for(uint8_t c=0;c<=5;c++,mEnv_ptr++){
        mEnv_ptr->nextWaitTimeMs=0;
        mEnv_ptr->attackCount=0;
        mEnv_ptr->decayCount=0;
        mEnv_ptr->sustainReleaseCount=0;
        if(wDDS[c].modularFreq!=0){
          if(mEnv_ptr->attackDuration!=0){
            mEnv_ptr->status=ATTACK;
          }else if(mEnv_ptr->decayDuration!=0){
            mEnv_ptr->status=DECAY;
          }else if(mEnv_ptr->sustainDuration!=0){
            mEnv_ptr->status=SUSTAIN;
          }else if(mEnv_ptr->releaseDuration!=0){
            mEnv_ptr->status=RELEASE;
          }else{
            mEnv_ptr->status=CONSTANT;
          }
          if(mEnv_ptr->status==ATTACK){
            if(mEnv_ptr->isAllowOverrideAttackDuty){
              mEnv_ptr->calculatedDuty=0;
            }
          }else{
            mEnv_ptr->calculatedDuty=255;
          }
        }else{
          mEnv_ptr->status = MUTE;
        }
        if(wDDS[c].isOnlyDetuneDuringSR){
          wDDS[c].outputVolumeDetune = 0;
        }else{
          wDDS[c].outputVolumeDetune = wDDS[c].volumeDetune;
        }
      }

      OCR0A=255;
      OCR0B=255;
      TIMSK1 |= 0b00000010;  //Timer1 COMPA割込み有効
      TIMSK2 |= 0b00000010;  //Timer2 COMPA割込み有効
      TCCR0A |= 0b11110000;  //PWM反転出力許可
    }
    if((PINC&0b00000010)==0b00000000&&isBottonPushed){
      isBottonPushed = false;
    }
  }else{
    //楽曲データ進行、エンベロープ処理
    struct envelope *cEnv_ptr = &cEnv(0);
    struct envelope *mEnv_ptr = &mEnv(0);
    struct conductor *CON_ptr = &CON[0];
    for(uint8_t c = 0;c<=5;c++,cEnv_ptr++,mEnv_ptr++,CON_ptr++){
      if(CON_ptr->beepMs>=CON_ptr->beepDuration){
        CON_ptr->beepMs-=CON[c].beepDuration;
        uint16_t beepFreq;
        beepFreq = nextBeepNote(c);
        //コマンド処理
        while(beepFreq>=65000){
          commandExecute(c,beepFreq);
          beepFreq = nextBeepNote(c);
        }
        //チャンネル初期化
        if(beepFreq!=0){
          CON_ptr->freq = beepFreq<<1;//フラッシュから楽曲データをコピー、値を2倍にして渡すことで高速処理部でレジスタ移動による0クロックで256除算を行う
          uint32_t tmp;
          u16u16Mul(tmp, CON_ptr->freq, wDDS[c].detunePitchDivide32768);
          wDDS[c].carrierDetuneFreq=tmp>>15;
          if(LFO[c].changeValue==0||LFO[c].isConvergence||LFO[c].isInitializeModulationIndex){
              wDDS[c].modularIndexDivide256=wDDS[c].tempModularIndexDivide256;
          }
          if(LFO[c].isConvergence||LFO[c].isInitializeModulationIndex){
            LFO[c].mode=false;
          }
          u16u16Mul(tmp, CON_ptr->freq, wDDS[c].modularFreqRatioDivide256);
          wDDS[c].modularFreq=tmp>>8;
          wDDS[c].outputVolumeDetune = wDDS[c].volumeDetune;
          //エンベロープ初期化
          cEnv_ptr->nextWaitTimeMs=0;
          cEnv_ptr->attackCount=0;
          cEnv_ptr->decayCount=0;
          cEnv_ptr->sustainReleaseCount=0;
          if(wDDS[c].isOnlyDetuneDuringSR){
            wDDS[c].outputVolumeDetune = 0;
          }else{
            wDDS[c].outputVolumeDetune = wDDS[c].volumeDetune;
          }
          if(cEnv_ptr->attackDuration!=0){
            cEnv_ptr->status=ATTACK;
          }else if(cEnv_ptr->decayDuration!=0){
            cEnv_ptr->status=DECAY;
          }else if(cEnv_ptr->sustainDuration!=0){
            cEnv_ptr->status=SUSTAIN;
          }else{
            cEnv_ptr->status=CONSTANT;
          }
          if(cEnv_ptr->status==ATTACK){
            if(cEnv_ptr->isAllowOverrideAttackDuty){
              cEnv_ptr->calculatedDuty=0;
            }
          }else{
            cEnv_ptr->calculatedDuty=255;
          }
        }else if(cEnv_ptr->releaseDuration==0){
          cEnv_ptr->status=MUTE;
        }else{
          if(cEnv_ptr->isEnableRelease){
            cEnv_ptr->status=RELEASE;
          }else{
            cEnv_ptr->status=MUTE;
          }
        }
        
        if(beepFreq!=0){
          //エンベロープ初期化
          mEnv_ptr->nextWaitTimeMs=0;
          mEnv_ptr->attackCount=0;
          mEnv_ptr->decayCount=0;
          mEnv_ptr->sustainReleaseCount=0;
          if(mEnv_ptr->attackDuration!=0){
            mEnv_ptr->status=ATTACK;
          }else if(mEnv_ptr->decayDuration!=0){
            mEnv_ptr->status=DECAY;
          }else if(mEnv_ptr->sustainDuration!=0){
            mEnv_ptr->status=SUSTAIN;
          }else{
            mEnv_ptr->status=CONSTANT;
          }
          if(mEnv_ptr->status==ATTACK){
            if(mEnv_ptr->isAllowOverrideAttackDuty){
              mEnv_ptr->calculatedDuty=0;
            }
          }else{
            mEnv_ptr->calculatedDuty=255;
          }
        }else if(mEnv_ptr->releaseDuration==0){
          mEnv_ptr->status=CONSTANT;
        }else{
          if(mEnv_ptr->isEnableRelease){
            mEnv_ptr->status=RELEASE;
          }else{
            mEnv_ptr->status=MUTE;
          }
        }
      }
    }
    //noise
    if(CON[6].beepMs>=CON[6].beepDuration){
      CON[6].beepMs-=CON[6].beepDuration;
      uint16_t getNoiseFreq;
      getNoiseFreq = nextNoiseNote();
      //コマンド処理
      while(getNoiseFreq>=65000){
        commandExecute(6,getNoiseFreq);
        getNoiseFreq = nextNoiseNote();
      }
      if(getNoiseFreq!=0){
        //エンベロープ初期化
        cEnv(6).nextWaitTimeMs=0;
        cEnv(6).attackCount=0;
        cEnv(6).decayCount=0;
        cEnv(6).sustainReleaseCount=0;
        CON[6].freq = getNoiseFreq<<1;//フラッシュから楽曲データをコピー、値を2倍にして渡すことで高速処理部でレジスタ移動による0クロックで256除算を行う
        if(cEnv(6).attackDuration!=0){
          cEnv(6).status=ATTACK;
        }else if(cEnv(6).decayDuration!=0){
          cEnv(6).status=DECAY;
        }else if(cEnv(6).sustainDuration!=0){
          cEnv(6).status=SUSTAIN;
        }else if(cEnv(6).releaseDuration!=0){
          cEnv(6).status=RELEASE;
        }else{
          cEnv(6).status=CONSTANT;
        }
        if(cEnv(6).status==ATTACK){
          if(cEnv(6).isAllowOverrideAttackDuty){
            cEnv(6).calculatedDuty=0;
          }
        }else{
          cEnv(6).calculatedDuty=255;
        }
      }else if(cEnv(6).releaseDuration==0){
        cEnv(6).status=MUTE;
      }else{
        if(cEnv(6).isEnableRelease){
          cEnv(6).status=RELEASE;
        }else{
          cEnv(6).status=MUTE;
        }
      }
    }
    struct envelope *env_ptr = &env[0];
    for(uint8_t c=0;c<=12;c++,env_ptr++){
      //Envelope
      if(env_ptr->status==ATTACK){
        if(env_ptr->nextWaitTimeMs>=env_ptr->attackDuration){
          env_ptr->nextWaitTimeMs-=env_ptr->attackDuration;
          uint8_t newEnvelopeDuty = (uint8_t)((int16_t)pgm_read_byte(sinSampling+191-env_ptr->attackCount)+128);
          env_ptr->calculatedDuty=(env_ptr->calculatedDuty>newEnvelopeDuty)? env_ptr->calculatedDuty : newEnvelopeDuty;
          if(env_ptr->attackCount+env_ptr->attackChangeValue<128){
            env_ptr->attackCount+=env_ptr->attackChangeValue;
          }else{
            if(env_ptr->decayDuration!=0){
              env_ptr->status=DECAY;
            }else if(env_ptr->sustainDuration!=0){
              env_ptr->status=SUSTAIN;
            }else{
              env_ptr->status=CONSTANT;
            }
          }
        }
      }else if(env_ptr->status==DECAY){
        if(env_ptr->nextWaitTimeMs>=env_ptr->decayDuration){
          env_ptr->nextWaitTimeMs-=env_ptr->decayDuration;
          uint8_t newEnvelopeDuty = (uint8_t)((int16_t)pgm_read_byte(sinSampling+63-env_ptr->decayCount)+128);
          env_ptr->calculatedDuty=(env_ptr->calculatedDuty>newEnvelopeDuty)? newEnvelopeDuty : env_ptr->calculatedDuty;
          if(env_ptr->decayCount+env_ptr->decayChangeValue<64){
            env_ptr->decayCount+=env_ptr->decayChangeValue;
          }else{
            if(env_ptr->sustainDuration!=0){
              env_ptr->status=SUSTAIN;
            }else{
              env_ptr->status=CONSTANT;
            }
          }
        }
      }else if(env_ptr->status==SUSTAIN){
        if(env_ptr->nextWaitTimeMs>=env_ptr->sustainDuration&&env_ptr->calculatedDuty>env_ptr->sustainLowerValue){
          env_ptr->nextWaitTimeMs-=env_ptr->sustainDuration;
          switch(env_ptr->sustainMode){
            case 0:
              env_ptr->calculatedDuty=(252-(env_ptr->sustainReleaseCount<<2))>>(env_ptr->decayDuration!=0x00);
              break;
            case 1:
              env_ptr->calculatedDuty = pgm_read_byte(expReleaseDuty+env_ptr->sustainReleaseCount)>>(env_ptr->decayDuration!=0x00);
              break;
            case 2:
              env_ptr->calculatedDuty = pgm_read_byte(cosReleaseDuty+env_ptr->sustainReleaseCount)>>(env_ptr->decayDuration!=0x00);
              break;
          }
          if(env_ptr->sustainReleaseCount+env_ptr->sustainChangeValue<64){
            env_ptr->sustainReleaseCount+=env_ptr->sustainChangeValue;
          }else{
            env_ptr->status=CONSTANT;
          }
        }
      }else if(env_ptr->status==RELEASE){
        if(env_ptr->nextWaitTimeMs>=env_ptr->releaseDuration&&env_ptr->calculatedDuty>env_ptr->releaseLowerValue){
          env_ptr->nextWaitTimeMs-=env_ptr->releaseDuration;
          switch(env_ptr->releaseMode){
            case 0:
              env_ptr->calculatedDuty = (252-(env_ptr->sustainReleaseCount<<2))>>(env_ptr->decayDuration!=0x00);
              break;
            case 1:
              env_ptr->calculatedDuty = pgm_read_byte(expReleaseDuty+env_ptr->sustainReleaseCount)>>(env_ptr->decayDuration!=0x00);
              break;
            case 2:
              env_ptr->calculatedDuty = pgm_read_byte(cosReleaseDuty+env_ptr->sustainReleaseCount)>>(env_ptr->decayDuration!=0x00);
              break;
          }
          if(env_ptr->sustainReleaseCount+env_ptr->releaseChangeValue<64){
            env_ptr->sustainReleaseCount+=env_ptr->releaseChangeValue;
          }else{
            env_ptr->status=CONSTANT;
          }
        }
      }else if(env_ptr->status==MUTE){
        env_ptr->calculatedDuty = 0;
      }
    }
    CON_ptr = &CON[0];
    struct pitchBend *pb_ptr = &pb[0];
    for(uint8_t c=0;c<=6;c++,pb_ptr++,CON_ptr++){
      //pitch bend
      if(pb_ptr->nextWaitTimeMs>=pb_ptr->interval){
        pb_ptr->nextWaitTimeMs=0;
        uint32_t tmp;
        u16u16Mul(tmp, CON_ptr->freq, pb_ptr->ratioDivide32768);
        if(pb_ptr->ratioDivide32768>32768){
          if((tmp>>16)<pb_ptr->higherFreq){
            CON_ptr->freq=tmp>>15;
          }else{
            CON_ptr->freq=pb_ptr->higherFreq<<1;
          }
        }else if(pb_ptr->ratioDivide32768<32768){
          if((tmp>>16)>pb_ptr->lowerFreq){
            CON_ptr->freq=tmp>>15;
          }else{
            CON_ptr->freq=pb_ptr->lowerFreq<<1;
          }
        }
        if(c<=5){
          u16u16Mul(tmp, CON_ptr->freq, wDDS[c].modularFreqRatioDivide256);
          wDDS[c].modularFreq=tmp>>8;
        }
      }
    }
    struct LFO *LFO_ptr = &LFO[0];
    for(uint8_t c=0;c<=5;c++,LFO_ptr++){
      //Low Frequency Oscillator
      if((LFO_ptr->nextWaitTimeMs>LFO_ptr->duration)&&cEnv(c).calculatedDuty!=0){
        LFO_ptr->nextWaitTimeMs-=LFO_ptr->duration;
        if(!LFO_ptr->mode||!LFO_ptr->isConvergence){
          if(LFO_ptr->mode){
            if(((uint16_t)(wDDS[c].modularIndexDivide256+LFO_ptr->changeValue))>=(uint16_t)wDDS[c].tempModularIndexDivide256){
              wDDS[c].modularIndexDivide256=wDDS[c].tempModularIndexDivide256;
              LFO_ptr->mode=false;
            }else{
              wDDS[c].modularIndexDivide256=wDDS[c].modularIndexDivide256+LFO_ptr->changeValue;
            }
          }else{
            if((uint16_t)wDDS[c].modularIndexDivide256>(uint16_t)(LFO_ptr->changeValue+LFO_ptr->lowerValue)){
              wDDS[c].modularIndexDivide256=wDDS[c].modularIndexDivide256-LFO_ptr->changeValue;
            }else{
              wDDS[c].modularIndexDivide256=LFO_ptr->lowerValue;
              LFO_ptr->mode=true;
            }
          }
        }
      }
      //calc outputModularEnvelopeDuty.
      mEnv(c).outputDuty = ((uint16_t)mEnv(c).calculatedDuty*(uint16_t)wDDS[c].modularIndexDivide256)>>8;
    }
    //基準時間加算、チャンネル出力許可、ボリューム乗算処理。LED点灯
    if(refMs>0){
      TIMSK2 &= 0b11111101;  //Timer2 COMPA割込み禁止
      byte getMs = refMs;
      refMs=0;
      TIMSK2 |= 0b00000010;  //Timer2 COMPA割込み有効
      envelope *env_ptr = &env[0];
      for(uint8_t c=0;c<=12;c++,env_ptr++){
        env_ptr->nextWaitTimeMs+=getMs;
      }
      for(uint8_t c=0;c<=5;c++){
        CON[c].beepMs+=getMs;
        LFO[c].nextWaitTimeMs+=getMs;
        pb[c].nextWaitTimeMs+=getMs;
        if(cEnv(c).sustainReleaseCount!=0){
          wDDS[c].outputVolumeDetune = wDDS[c].outputVolumeDetune<wDDS[c].volumeDetune?wDDS[c].outputVolumeDetune+1:wDDS[c].volumeDetune;
        }

        if((*SW_AssignPORT[c]&SW_AssignDATA[c])==0b00000000){
          if(cEnv(c).calculatedDuty!=0){
            *LED_AssignPORT[c] |= LED_AssignDATA[c];
          }else{
            wDDS[c].carrierOperator=0;
            wDDS[c].carrierDetuneOperator=0;
            wDDS[c].modularOperator=0;
            *LED_AssignPORT[c] &= ~LED_AssignDATA[c];
          }
          cEnv(c).outputDuty=((uint16_t)cEnv(c).calculatedDuty*(uint16_t)wDDS[c].volume)>>8;
          wDDS[c].outputCarrierDetuneDuty=((uint16_t)cEnv(c).calculatedDuty*(uint16_t)wDDS[c].outputVolumeDetune)>>8;
        }else{
          *LED_AssignPORT[c] &= ~LED_AssignDATA[c];
          cEnv(c).outputDuty=0;
          wDDS[c].outputCarrierDetuneDuty=0;
        }
      }
      CON[6].beepMs+=getMs;
      pb[6].nextWaitTimeMs+=getMs;
      if((*SW_AssignPORT[6]&SW_AssignDATA[6])==0b00000000){
        if(cEnv(6).calculatedDuty!=0){
          *LED_AssignPORT[6] |= LED_AssignDATA[6];
        }else{
          *LED_AssignPORT[6] &= ~LED_AssignDATA[6];
        }
        cEnv(6).outputDuty=((uint16_t)cEnv(6).calculatedDuty*(uint16_t)nDDS.volume)>>8;
      }else{
        *LED_AssignPORT[6] &= ~LED_AssignDATA[6];
        cEnv(6).outputDuty=0;
      }
      //ピン入力検知
      if((PINC&0b00000010)==0b00000010&&!isBottonPushed){
        isBottonPushed = true;
        TIMSK1 &= 0b11111101;  //Timer1 COMPA割込み禁止
        TIMSK2 &= 0b11111101;  //Timer2 COMPA割込み禁止
        TCCR0A &= 0b00001111;  //PWM反転出力禁止
        PORTD &= 0b00000011;
        PORTB &= 0b11111000;
      }
      if((PINC&0b00000010)==0b00000000&&isBottonPushed){
        isBottonPushed = false;
      }
    }
  }
}
