//各チャンネルフラッシュアドレスインデックスオフセット
constexpr uint16_t* beepFreqChAddressOffset[7] = {beepFreqCh0,beepFreqCh1,beepFreqCh2,beepFreqCh3,beepFreqCh4,beepFreqCh5,noiseFreq};
constexpr uint16_t* beepDurationChAddressOffset[7] = {beepDurationCh0,beepDurationCh1,beepDurationCh2,beepDurationCh3,beepDurationCh4,beepDurationCh5,noiseDuration};
