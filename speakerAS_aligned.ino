uint16_t nextBeepNote(uint8_t c){
  CON[c].address++;
  uint16_t beepFreq = pgm_read_word(beepFreqChAddressOffset[c]+CON[c].address);
  if(beepFreq==0xffff){
    CON[c].address=CON[c].returnAddress;
    beepParmInit(c);
    beepFreq = pgm_read_word(beepFreqChAddressOffset[c]+CON[c].address);
  }
  CON[c].beepDuration = pgm_read_word(beepDurationChAddressOffset[c]+CON[c].address);
  return beepFreq;
}
void beepParmInit(uint8_t c){
  //パラメータ初期化
  wDDS[c].carrierSamplingTable=InitCarrierSamplingTable[c];
  wDDS[c].carrierDetuneSamplingTable=InitCarrierDetuneSamplingTable[c];
  wDDS[c].modularSamplingTable=InitModularSamplingTable[c];
  wDDS[c].volume=InitVolumeCh[c];
  wDDS[c].volumeDetune=InitVolumeDetuneCh[c];
  //CON[c].returnAddress=InitLoopAddressCh[c];
  cEnv(c).attackDuration=InitCarrierEnvelopeAttackDuration[c];
  cEnv(c).decayDuration=InitCarrierEnvelopeDecayDuration[c];
  cEnv(c).sustainDuration=InitCarrierEnvelopeSustainDuration[c];
  cEnv(c).releaseDuration=InitCarrierEnvelopeReleaseDuration[c];
  cEnv(c).attackChangeValue=InitCarrierEnvelopeAttackChangeValue[c];
  cEnv(c).decayChangeValue=InitCarrierEnvelopeDecayChangeValue[c];
  cEnv(c).sustainChangeValue=InitCarrierEnvelopeSustainChangeValue[c];
  cEnv(c).releaseChangeValue=InitCarrierEnvelopeReleaseChangeValue[c];
  cEnv(c).sustainLowerValue=InitCarrierEnvelopeSustainLowerValue[c];
  cEnv(c).releaseLowerValue=InitCarrierEnvelopeReleaseLowerValue[c];
  cEnv(c).isAllowOverrideAttackDuty=InitIsAllowOverrideCarrierAttackDuty[c];
  cEnv(c).sustainMode=InitCarrierEnvelopeSustainMode[c];
  cEnv(c).releaseMode=InitCarrierEnvelopeReleaseMode[c];
  cEnv(c).isEnableRelease=InitIsAllowCarrierInterNoteRelease[c];

  mEnv(c).attackDuration=InitModularEnvelopeAttackDuration[c];
  mEnv(c).decayDuration=InitModularEnvelopeDecayDuration[c];
  mEnv(c).sustainDuration=InitModularEnvelopeSustainDuration[c];
  mEnv(c).releaseDuration=InitModularEnvelopeReleaseDuration[c];
  mEnv(c).attackChangeValue=InitModularEnvelopeAttackChangeValue[c];
  mEnv(c).decayChangeValue=InitModularEnvelopeDecayChangeValue[c];
  mEnv(c).sustainChangeValue=InitModularEnvelopeSustainChangeValue[c];
  mEnv(c).releaseChangeValue=InitModularEnvelopeReleaseChangeValue[c];
  mEnv(c).sustainLowerValue=InitModularEnvelopeSustainLowerValue[c];
  mEnv(c).releaseLowerValue=InitModularEnvelopeReleaseLowerValue[c];
  mEnv(c).isAllowOverrideAttackDuty=InitIsAllowOverrideModularAttackDuty[c];
  mEnv(c).sustainMode=InitModularEnvelopeSustainMode[c];
  mEnv(c).releaseMode=InitModularEnvelopeReleaseMode[c];
  mEnv(c).isEnableRelease=InitIsAllowModularInterNoteRelease[c];

  wDDS[c].isOnlyDetuneDuringSR=InitIsOnlyDetuneDuringSR[c];
  wDDS[c].detunePitchDivide32768=InitDetunePitchDivide32768[c];
  wDDS[c].modularFeedbackGainDivide256=InitModulationFeedbackGainDivide256[c];
  wDDS[c].tempModularIndexDivide256=InitModulationIndexDivide256[c];
  wDDS[c].modularFreqRatioDivide256=InitModulationFreqRatioDivide256[c];
  LFO[c].duration=InitModulationLFODuration[c];
  LFO[c].changeValue=InitModulationLFOChangeValue[c];
  LFO[c].lowerValue = InitModulationIndexDivide256[c]>InitModulationLFOLowerValue[c] ? InitModulationLFOLowerValue[c] : InitModulationIndexDivide256[c];
  LFO[c].isConvergence=InitIsModulationLFOOnce[c];
  LFO[c].isInitializeModulationIndex=InitIsInitializeModulationIndex[c];
  if(LFO[c].changeValue==0||LFO[c].isConvergence||LFO[c].isInitializeModulationIndex){
    wDDS[c].modularIndexDivide256=wDDS[c].tempModularIndexDivide256;
  }
  if(LFO[c].isConvergence||LFO[c].isInitializeModulationIndex){
    LFO[c].mode=false;
  }
  pb[c].interval = InitPitchBendInterval[c];
  pb[c].ratioDivide32768 = InitPitchBendRatioDivide32768[c];
  pb[c].higherFreq = InitPitchBendHigherFreq[c];
  pb[c].lowerFreq = InitPitchBendLowerFreq[c];
}
uint16_t nextNoiseNote(void){
  CON[6].address++;
  uint16_t getNoiseFreq = pgm_read_word(&noiseFreq[CON[6].address]);
  if(getNoiseFreq==0xffff){
    CON[6].address=CON[6].returnAddress;
    noiseParmInit();
    getNoiseFreq = pgm_read_word(&noiseFreq[CON[6].address]);
  }
  CON[6].beepDuration = pgm_read_word(&noiseDuration[CON[6].address]);
  return getNoiseFreq;
}
